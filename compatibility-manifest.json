{
  "schemaVersion": 1,
  "description": "Platform support matrix for Claude OS validators; keys align with docs/COMPATIBILITY.md.",
  "platformCatalog": [
    {
      "id": "win-ps-5.1",
      "label": "Windows PowerShell 5.1",
      "rationale": "Legacy powershell.exe host; orchestrators may spawn pwsh child processes."
    },
    {
      "id": "win-pwsh",
      "label": "PowerShell 7 on Windows",
      "rationale": "Primary Windows target for repo tooling."
    },
    {
      "id": "linux-pwsh",
      "label": "PowerShell 7 on Linux",
      "rationale": "CI and developer Linux shells using pwsh."
    },
    {
      "id": "macos-pwsh",
      "label": "PowerShell 7 on macOS",
      "rationale": "Developer macOS with PowerShell Core."
    },
    {
      "id": "bash-on-path",
      "label": "POSIX Bash on PATH",
      "rationale": "Native bash (Linux/macOS) or bash available without Git-Bash-specific paths."
    },
    {
      "id": "git-bash",
      "label": "Git for Windows Bash",
      "rationale": "MINGW64/MSYS bash from Git for Windows."
    },
    {
      "id": "wsl",
      "label": "WSL Linux distro",
      "rationale": "Validators run from pwsh on Windows against Linux userland via WSL."
    },
    {
      "id": "gha-ubuntu",
      "label": "GitHub Actions ubuntu-latest",
      "rationale": "Typical Linux CI agent with pwsh and bash packages."
    },
    {
      "id": "gha-windows",
      "label": "GitHub Actions windows-latest",
      "rationale": "Typical Windows CI agent with pwsh; bash optional."
    }
  ],
  "defaultSupport": {
    "win-ps-5.1": "best-effort",
    "win-pwsh": "supported",
    "linux-pwsh": "supported",
    "macos-pwsh": "supported",
    "bash-on-path": "not-applicable",
    "git-bash": "not-applicable",
    "wsl": "not-applicable",
    "gha-ubuntu": "supported",
    "gha-windows": "supported"
  },
  "validators": [
    {
      "id": "evaluate-quality-gate"
    },
    {
      "id": "os-doctor",
      "overrides": {
        "bash-on-path": "best-effort",
        "git-bash": "best-effort",
        "wsl": "best-effort"
      }
    },
    {
