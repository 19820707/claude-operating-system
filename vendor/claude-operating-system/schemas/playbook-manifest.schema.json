{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "os-playbook-manifest",
  "title": "Claude OS playbook manifest",
  "type": "object",
  "required": ["schemaVersion", "canonicalRoot", "playbooks"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "canonicalRoot": { "type": "string", "minLength": 2 },
    "playbooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "path",
          "riskLevel",
          "summary",
          "requiresApprovalFor"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 8 },
          "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "summary": { "type": "string", "minLength": 8 },
          "requiresApprovalFor": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relatedSkills": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
