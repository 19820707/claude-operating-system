{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "os-skills-manifest",
  "title": "Claude OS canonical skills manifest",
  "type": "object",
  "required": ["schemaVersion", "canonicalRoot", "skills"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "canonicalRoot": { "type": "string", "minLength": 2 },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "path",
          "maturity",
          "status",
          "summary",
          "intendedUse",
          "riskLevel",
          "requiresApprovalFor",
          "allowedAgents",
          "generatedTargets",
          "contextBudget",
          "dependencies",
          "relatedPolicies"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 8 },
          "maturity": { "type": "string", "enum": ["stable", "experimental", "internal", "deprecated"] },
          "status": { "type": "string", "enum": ["active", "draft", "deprecated"] },
          "owners": {
            "type": "array",
            "items": { "type": "string" }
          },
          "summary": { "type": "string", "minLength": 8 },
          "intendedUse": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "requiresApprovalFor": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowedAgents": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["claude", "cursor", "codex"] }
          },
          "generatedTargets": {
            "type": "array",
            "items": { "type": "string", "minLength": 4 }
          },
          "contextBudget": {
            "type": "object",
            "required": ["maxLines", "maxBytes"],
            "additionalProperties": false,
            "properties": {
              "maxLines": { "type": "integer", "minimum": 50 },
              "maxBytes": { "type": "integer", "minimum": 1024 }
            }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relatedPolicies": {
            "type": "array",
            "items": { "type": "string", "minLength": 4 }
          },
          "examples": { "type": "array", "items": { "type": "string" } },
          "tests": { "type": "array", "items": { "type": "string" } },
          "examplesExemptionReason": {
            "type": "string",
            "minLength": 12,
            "description": "Required when examples and tests are both empty"
          }
        }
      }
    },
    "releaseProfileIds": {
      "type": "array",
      "description": "Runtime profile ids treated as release/strict for deprecated gating",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
