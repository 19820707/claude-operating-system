{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude OS Workflow Manifest",
  "type": "object",
  "required": ["schemaVersion", "phases", "globalRules", "artifactFirstPaths"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "phases": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "purpose", "requiredArtifacts", "recommendedCapability", "gate"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "requiredArtifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "recommendedCapability": { "type": "string", "pattern": "^os\\." },
          "gate": { "type": "string", "minLength": 1 }
        }
      }
    },
    "globalRules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "artifactFirstPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
