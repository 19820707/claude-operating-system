{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-os.local/schemas/distribution-manifest.schema.json",
  "title": "Claude OS distribution manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "description",
    "outputZipRelative",
    "stagingDirectoryRelative",
    "rootFiles",
    "includeTrees",
    "excludePathRegexes",
    "mandatoryPackagedPaths"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string", "minLength": 1 },
    "outputZipRelative": {
      "type": "string",
      "minLength": 4,
      "description": "Zip path relative to repo root (forward slashes)"
    },
    "stagingDirectoryRelative": {
      "type": "string",
      "minLength": 2,
      "description": "Temporary staging folder under repo (removed after pack)"
    },
    "rootFiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "includeTrees": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "skipPathPrefixes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "excludePathRegexes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mandatoryPackagedPaths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
