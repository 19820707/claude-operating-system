{
  "schemaVersion": 1,
  "description": "Authoritative include list for a portable Claude OS distribution zip. Root-local generated mirrors, secrets, logs, evidence, and CI-only test trees are excluded.",
  "outputZipRelative": "dist/claude-os-distribution.zip",
  "stagingDirectoryRelative": "dist/pack-staging",
  "rootFiles": [
    "ARCHITECTURE.md",
    "CLAUDE.md",
    "GIT-RECOVERY.md",
    "INDEX.md",
    "README.md",
    "SECURITY.md",
    "OS_WORKSPACE_CONTEXT.template.md",
    "OPERATOR_JOURNAL.template.md",
    "install.ps1",
    "install.sh",
    "init-project.ps1",
    "agent-adapters-manifest.json",
    "bootstrap-manifest.json",
    "capability-manifest.json",
    "compatibility-manifest.json",
    "component-manifest.json",
    "context-budget.json",
    "deprecation-manifest.json",
    "distribution-manifest.json",
    "docs-index.json",
    "lifecycle-manifest.json",
    "os-capabilities.json",
    "os-manifest.json",
    "playbook-manifest.json",
    "policies/autonomy-policy.json",
    "recipe-manifest.json",
    "runtime-budget.json",
    "runtime-profiles.json",
    "script-manifest.json",
    "session-memory-manifest.json",
    "skills-manifest.json",
    "upgrade-manifest.json",
    "workflow-manifest.json"
  ],
  "includeTrees": [
    { "path": "policies" },
    { "path": "prompts" },
    { "path": "heuristics" },
    { "path": "schemas" },
    { "path": "quality-gates" },
    { "path": "tools" },
    {
      "path": "templates",
      "skipPathPrefixes": [
        "templates/invariant-engine/node_modules/"
      ]
    },
    { "path": "source/skills" },
    { "path": "docs" },
    { "path": "playbooks" },
    { "path": "recipes" },
    { "path": "examples" }
  ],
  "excludePathRegexes": [
    "(?i)(^|/)OS_WORKSPACE_CONTEXT\\.md$",
    "(?i)(^|/)OPERATOR_JOURNAL\\.md$",
    "(?i)^\\.claude/skills(/|$)",
    "(?i)^\\.cursor/skills(/|$)",
    "(?i)^\\.codex/skills(/|$)",
    "(?i)^logs(/|$)",
    "(?i)^local-evidence(/|$)",
    "(?i)^evidence/local(/|$)",
    "(?i)^exports(/|$)",
    "(?i)^extern-reference(/|$)",
    "(?i)^claude-operating-system(/|$)",
    "(?i)^dist/pack-staging(/|$)",
    "(?i)^dist/claude-os-distribution\\.zip$",
    "(?i)(^|/)\\.env$",
    "(?i)(^|/)\\.env\\.",
    "(?i)\\.local-backup\\.ps1$",
    "(?i)(^|/)settings\\.local\\.json$",
    "(?i)^tests(/|$)",
    "(?i)\\.git(/|$)"
  ],
  "mandatoryPackagedPaths": [
    "install.ps1",
    "bootstrap-manifest.json",
    "tools/os-runtime.ps1",
    "tools/os-validate.ps1",
    "tools/init-os-runtime.ps1",
    "tools/os-update-project.ps1",
    "policies/production-safety.md",
    "schemas/script-manifest.schema.json",
    "source/skills/production-safety/SKILL.md",
    "docs/QUICKSTART.md"
  ]
}
