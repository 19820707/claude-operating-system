{
  "schemaVersion": 1,
  "runtime": {
    "name": "Claude OS Runtime",
    "version": "1.0.0",
    "level": "advanced-engineering-runtime",
    "stability": "pre-production",
    "contract": "local-first, deterministic, manifest-governed, human-gated for critical surfaces"
  },
  "description": "Master manifest for Claude OS Runtime orchestration. References canonical subsystem manifests without duplicating their full contents.",
  "manifests": {
    "bootstrap": "bootstrap-manifest.json",
    "docs": "docs-index.json",
    "invariants": "invariants-manifest.json",
    "capabilities": "os-capabilities.json",
    "capabilityRoutes": "capability-manifest.json",
    "workflow": "workflow-manifest.json",
    "runtimeProfiles": "runtime-profiles.json",
    "sessionMemory": "session-memory-manifest.json",
    "gitRecoveryPolicy": "GIT-RECOVERY.md",
    "agentAdapters": "agent-adapters-manifest.json",
    "skillsManifest": "skills-manifest.json",
    "playbooksManifest": "playbook-manifest.json",
    "recipesManifest": "recipe-manifest.json",
    "deprecations": "deprecation-manifest.json",
    "components": "component-manifest.json",
    "compatibility": "compatibility-manifest.json",
    "lifecycle": "lifecycle-manifest.json",
    "distribution": "distribution-manifest.json",
    "upgradeManifest": "upgrade-manifest.json",
    "autonomyPolicy": "policies/autonomy-policy.json"
  },
  "entrypoints": {
    "runtime": "tools/os-runtime.ps1",
    "initRuntime": "tools/init-os-runtime.ps1",
    "validateProfiles": "tools/os-validate.ps1",
    "health": "tools/verify-os-health.ps1",
    "gitHygiene": "tools/verify-git-hygiene.ps1",
    "secretLint": "tools/verify-no-secrets.ps1",
    "agentAdaptersVerify": "tools/verify-agent-adapters.ps1",
    "runtimeDispatcherVerify": "tools/verify-runtime-dispatcher.ps1",
    "doctor": "tools/os-doctor.ps1",
    "validateAll": "tools/os-validate-all.ps1",
    "updateProject": "tools/os-update-project.ps1",
    "route": "tools/route-capability.ps1",
    "docs": "tools/query-docs-index.ps1",
    "workflow": "tools/workflow-status.ps1",
    "runtimeProfile": "tools/runtime-profile.ps1",
    "sessionPrime": "tools/session-prime.ps1",
    "sessionAbsorb": "tools/session-absorb.ps1",
    "sessionDigest": "tools/session-digest.ps1"
  },
  "managedProjectArtifacts": [
    ".claude/docs-index.json",
    ".claude/os-capabilities.json",
    ".claude/capability-manifest.json",
    ".claude/deprecation-manifest.json",
    ".claude/workflow-manifest.json",
    ".claude/scripts/query-docs-index.ps1",
    ".claude/scripts/route-capability.ps1",
    ".claude/scripts/workflow-status.ps1",
    ".claude/scripts/session-prime.ps1",
    ".claude/scripts/session-absorb.ps1",
    ".claude/scripts/session-digest.ps1",
    ".claude/checklists/SECURITY-CHECKLIST.md",
    ".claude/checklists/RELEASE-CHECKLIST.md",
    "AGENTS.md",
    ".cursor/rules/claude-os-runtime.mdc",
    ".agent/runtime.md",
    ".agent/handoff.md",
    ".agent/operating-contract.md",
    ".agents/OPERATING_CONTRACT.md"
  ],
  "validationPolicy": {
    "defaultMode": "normal",
    "strictMode": "warnings become failures for doctor and generated scaffold verification",
    "requiredBeforeMerge": "pwsh ./tools/os-validate-all.ps1 -Strict",
    "releaseGate": "human approval required for runtime, bootstrap, CI, security, permissions, filesystem, and production-safety changes",
    "releaseContract": {
      "architectureRequiredSubstrings": ["Claude OS Runtime", "os-manifest.json", "init-project.ps1", "Invariants"],
      "changelogRequiredSubstrings": ["1.0.0", "Claude OS Runtime v1", "human approval required"],
      "securityRequiredSubstrings": ["human approval required", "secrets", "PII", "filesystem", "CI/CD"]
    }
  }
}
