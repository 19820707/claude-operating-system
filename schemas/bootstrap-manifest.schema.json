{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude OS Bootstrap Manifest",
  "type": "object",
  "required": ["schemaVersion", "skills", "repoIntegrity", "projectBootstrap"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "skills": {
      "type": "object",
      "required": ["exact", "categories"],
      "properties": {
        "exact": { "type": "integer", "minimum": 1 },
        "categories": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "repoIntegrity": { "type": "object", "minProperties": 1 },
    "projectBootstrap": {
      "type": "object",
      "required": ["scripts", "criticalPaths"],
      "properties": {
        "scripts": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[^/\\\\]+\\.sh$" }, "uniqueItems": true },
        "criticalPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
