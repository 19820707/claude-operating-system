{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude OS Capabilities Registry",
  "type": "object",
  "required": ["schemaVersion", "defaults", "capabilities"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "defaults": { "type": "object" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "intent", "skill", "risk", "cost", "tags", "entrypoint", "validations", "docs"],
        "properties": {
          "id": { "type": "string", "pattern": "^os\\.[a-z0-9]+([-.][a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "intent": { "type": "string", "minLength": 1 },
          "skill": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["low", "medium", "high", "critical"] },
          "cost": { "enum": ["low", "medium", "high"] },
          "tags": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } },
          "entrypoint": { "type": "string", "minLength": 1 },
          "validations": { "type": "array", "items": { "type": "string" } },
          "docs": { "type": "array", "items": { "type": "string" } },
          "requiresHumanApproval": { "type": "boolean" }
        }
      }
    }
  }
}
