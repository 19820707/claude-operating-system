{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-os.local/schemas/gate-result.schema.json",
  "$comment": "Instance document: gate-status-contract.json at repo root.",
  "title": "Claude OS gate-status contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "description",
    "onlyOkUnlocks",
    "canonicalStatuses",
    "passStatuses",
    "runtimeBudgetNeverTreatAsPassedMustInclude",
    "alignedSchemas"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "description": { "type": "string", "minLength": 1 },
    "onlyOkUnlocks": { "type": "boolean", "const": true },
    "canonicalStatuses": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["ok", "warn", "fail", "skip", "blocked", "degraded", "unknown", "not_run"]
      }
    },
    "passStatuses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "type": "string", "enum": ["ok"] }
    },
    "runtimeBudgetNeverTreatAsPassedMustInclude": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "alignedSchemas": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
