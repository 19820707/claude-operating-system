{
  "schemaVersion": 1,
  "description": "Maps Claude Code, Cursor, Codex, and neutral agent docs to the single operational runtime under .claude/",
  "adapters": [
    {
      "id": "claude-code",
      "entrypoint": "CLAUDE.md",
      "runtimePath": ".claude/",
      "managed": false,
      "purpose": "Claude Code project memory and operational policy; defers execution to .claude/"
    },
    {
      "id": "cursor",
      "entrypoint": ".cursor/rules/claude-os-runtime.mdc",
      "runtimePath": ".claude/",
      "managed": true,
      "purpose": "Cursor Project Rules (always-on); defers state and gates to .claude/"
    },
    {
      "id": "codex",
      "entrypoint": "AGENTS.md",
      "runtimePath": ".claude/",
      "managed": false,
      "purpose": "Thin contract for Codex and generic agents; bootstrap creates once, never overwritten by updater"
    },
    {
      "id": "neutral-agent-docs",
      "entrypoints": [
        ".agent/runtime.md",
        ".agent/handoff.md",
        ".agent/operating-contract.md",
        ".agents/OPERATING_CONTRACT.md"
      ],
      "runtimePath": ".claude/",
      "managed": true,
      "purpose": "Tool-neutral runtime summary, handoff protocol, operating contract, plus legacy .agents/ pointer for template compatibility"
    }
  ],
  "canonicalSources": {
    "skills": "source/skills/",
    "claudePolicy": "CLAUDE.md",
    "agentPolicy": "AGENTS.md"
  },
  "generatedTargets": [
    {
      "agent": "claude",
      "path": ".claude/skills",
      "source": "source/skills/"
    },
    {
      "agent": "cursor",
      "path": ".cursor/skills",
      "source": "source/skills/"
    },
    {
      "agent": "codex",
      "path": ".codex/skills",
      "source": "source/skills/"
    }
  ],
  "driftPolicy": {
    "generatedTargetsMustMatchCanonical": true,
    "manualEditsInGeneratedTargetsAreWarnings": true,
    "releaseRequiresNoDrift": true
  }
}
