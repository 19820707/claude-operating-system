{
  "approvalPolicy": "on-request",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/preflight.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-end.sh && bash .claude/scripts/os-telemetry.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/post-compact.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(npm run build *)",
      "Bash(npm run check *)",
      "Bash(npx tsc *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx eslint *)",
      "Bash(npx vitest run *)",
      "Bash(npx playwright test *)",
      "Bash(bash .claude/scripts/drift-detect.sh)",
      "Bash(bash .claude/scripts/heuristic-ratchet.sh *)",
      "Bash(bash .claude/scripts/ts-error-budget.sh *)",
      "Bash(bash .claude/scripts/os-telemetry.sh *)",
      "Bash(bash .claude/scripts/promote-heuristics.sh *)",
      "Bash(bash .claude/scripts/risk-surface-scan.sh)",
      "Bash(bash .claude/scripts/module-complexity.sh *)",
      "Bash(bash .claude/scripts/causal-trace.sh *)",
      "Bash(bash .claude/scripts/session-index-build.sh *)",
      "Bash(bash .claude/scripts/cross-project-inherit.sh *)",
      "Bash(bash .claude/scripts/preflight.sh)",
      "Bash(bash .claude/scripts/session-end.sh)"
    ],
    "deny": [
      "Read(.env)",
      "Edit(.env)",
      "Read(.env.local)",
      "Edit(.env.local)",
      "Read(.env.production)",
      "Edit(.env.production)",
      "Read(.env.development.local)",
      "Edit(.env.development.local)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --mirror *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(npm publish *)"
    ]
  }
}
